{
  "info": {
    "name": "SysEvents",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://sysevents-1.onrender.com"
    },
    {
      "key": "token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/health"
          }
        }
      ]
    },
    {
      "name": "Usuários",
      "item": [
        {
          "name": "Registrar",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/usuarios/registrar",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Nome Teste\",\n  \"email\": \"teste@email.com\",\n  \"senha\": \"Senha@123\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.token) pm.collectionVariables.set('token', res.data.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/usuarios/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"cleiton@admin.com\",\n  \"senha\": \"barbosa2018\"\n}"
            }
          }
        },
        {
          "name": "Meu Perfil",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/usuarios/perfil"
          }
        }
      ]
    },
    {
      "name": "Upload",
      "item": [
        {
          "name": "Upload Avatar",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/upload/avatar",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "avatar", "type": "file", "src": "" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Listar Usuários",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/admin/usuarios"
          }
        },
        {
          "name": "Listar Usuários (paginado)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/admin/usuarios?page=1&limit=10",
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Eventos",
      "item": [
        {
          "name": "Criar Evento",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/eventos",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"titulo\": \"Evento Teste\",\n  \"descricao\": \"Descrição do evento\",\n  \"local\": \"IFCE\",\n  \"dataInicio\": \"2026-07-01T09:00:00Z\",\n  \"dataFim\": \"2026-07-01T18:00:00Z\"\n}"
            }
          }
        },
        {
          "name": "Meus Eventos",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/eventos/meus/eventos"
          }
        },
        {
          "name": "Publicar Evento",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/eventos/6/publicar"
          }
        },
        {
          "name": "Buscar Evento por ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/eventos/4"
          }
        },
        {
          "name": "Filtrar - por status",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/eventos/filtrar?status=publicado&page=1&limit=10",
              "query": [
                { "key": "status", "value": "publicado" },
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Filtrar - por local",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/eventos/filtrar?local=IFCE",
              "query": [
                { "key": "local", "value": "IFCE" }
              ]
            }
          }
        },
        {
          "name": "Filtrar - por dataInicio",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/eventos/filtrar?dataInicio=2026-07-01",
              "query": [
                { "key": "dataInicio", "value": "2026-07-01" }
              ]
            }
          }
        },
        {
          "name": "Filtrar - por dataFim",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/eventos/filtrar?dataFim=2026-07-31",
              "query": [
                { "key": "dataFim", "value": "2026-07-31" }
              ]
            }
          }
        },
        {
          "name": "Filtrar - combinado",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/eventos/filtrar?status=publicado&local=São Paulo&dataInicio=2026-06-01&page=1&limit=10",
              "query": [
                { "key": "status", "value": "publicado" },
                { "key": "local", "value": "São Paulo" },
                { "key": "dataInicio", "value": "2026-06-01" },
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            }
          }
        }
      ]
    }
  ]
}
